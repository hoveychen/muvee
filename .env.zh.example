# muvee 环境配置模板
# 复制为 .env 并填写实际值

# ── 身份认证 Provider ──────────────────────────────────────────────────────────
# 至少配置一个 Provider。多个 Provider 可同时启用，登录页会为每个已启用的 Provider 显示一个登录按钮。

# Google OAuth2
# 配置步骤：
# 1. 打开 https://console.cloud.google.com/apis/credentials
# 2. 点击「创建凭证」→「OAuth 客户端 ID」，应用类型选「Web 应用」
# 3. 在「已授权的重定向 URI」中添加以下两个：
#    https://BASE_DOMAIN/auth/google/callback   ← 控制台登录回调
#    https://BASE_DOMAIN/_oauth                 ← 各 project ForwardAuth 回调
# 4. 创建完成后复制 Client ID 和 Client Secret 填入下方
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URL=https://example.com/auth/google/callback

# 飞书 / Lark OAuth2
# 配置步骤：https://open.feishu.cn/app → 创建应用 → 添加 OAuth2 权限：contact:user.email:readonly
# 在应用后台添加重定向 URI：https://BASE_DOMAIN/auth/feishu/callback
# 国际版 Lark 用户请设置 FEISHU_BASE_URL=https://open.larksuite.com
# 邮箱兜底：企业邮箱 → 个人邮箱 → {open_id}@feishu.local（见下方 ALLOWED_DOMAINS 说明）
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_REDIRECT_URL=https://example.com/auth/feishu/callback
# FEISHU_BASE_URL=https://open.feishu.cn

# 企业微信扫码 SSO
# 配置步骤：https://work.weixin.qq.com/wework_admin/frame#apps → 创建应用 → 配置网页授权
# 在应用后台添加重定向域名：BASE_DOMAIN，回调地址：https://BASE_DOMAIN/auth/wecom/callback
# 邮箱兜底：企业邮箱(biz_mail) → 个人邮箱 → {userid}@wecom.local（见下方 ALLOWED_DOMAINS 说明）
# WECOM_CORP_ID=your-corp-id
# WECOM_CORP_SECRET=your-corp-secret
# WECOM_AGENT_ID=your-agent-id
# WECOM_REDIRECT_URL=https://example.com/auth/wecom/callback

# 钉钉 OAuth2
# 配置步骤：https://open.dingtalk.com → 创建应用 → 配置「登录钉钉」功能
# 在应用后台添加回调地址：https://BASE_DOMAIN/auth/dingtalk/callback
# 邮箱兜底：个人邮箱 → {unionId}@dingtalk.local（见下方 ALLOWED_DOMAINS 说明）
# DINGTALK_CLIENT_ID=your-client-id
# DINGTALK_CLIENT_SECRET=your-client-secret
# DINGTALK_REDIRECT_URL=https://example.com/auth/dingtalk/callback

# 允许登录的邮箱域名（逗号分隔，留空允许所有账号）
# 对 Google：限制只有指定域名的账号可登录（如 your-company.com）。
# 对飞书 / 企微 / 钉钉：仅当 Provider 能返回真实邮箱地址时才校验域名。
# 若 Provider 无法提供邮箱，系统会生成以 .local 结尾的合成邮箱（如 abc123@feishu.local），
# 该类地址自动跳过域名校验——因为企业 SSO 本身已经限制了只有本组织成员才能登录。
ALLOWED_DOMAINS=your-company.com

# 管理员邮箱（逗号分隔）。这些用户登录时自动获得 admin 角色，且可访问 traefik.BASE_DOMAIN 控制面板
ADMIN_EMAILS=admin@your-company.com

# 系统根域名（project 将以 {name}.BASE_DOMAIN 访问，控制台入口为 BASE_DOMAIN 本身）
# DNS：需将 BASE_DOMAIN（A 记录）和 *.BASE_DOMAIN（通配符 A 记录）均指向本服务器 IP
BASE_DOMAIN=example.com

# JWT 签名密钥（生产环境请使用随机字符串）
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL 密码
POSTGRES_PASSWORD=change-me-postgres-password

# Let's Encrypt 通知邮箱
ACME_EMAIL=admin@example.com

# Docker Registry 配置
# 1. 生成 registry/htpasswd 文件（控制平面服务器上执行一次）：
#    docker run --entrypoint htpasswd httpd:2 -Bbn <user> <password> > registry/htpasswd
# 2. Agent 启动后会自动从控制平面拉取以下配置（/api/agent/config），无需在 agent 节点单独配置
REGISTRY_ADDR=registry.example.com
REGISTRY_USER=registry-user
REGISTRY_PASSWORD=change-me-registry-password

# 项目工作区卷基础路径（可选，不设置则禁用工作区功能）
#
# 开启后，每个项目会在此路径下自动创建独立子目录，并 bind mount 进已部署的容器。
#
# 单机 Standalone（docker-compose.yml，所有组件在同一台机器）：
#   填写本机任意本地目录，不存在时会自动创建。
#   示例：VOLUME_NFS_BASE_PATH=/opt/muvee/volumes
#   muvee-server 和 muvee-agent-deploy 容器均会以相同路径挂载该目录，
#   确保服务端文件管理 API、deploy agent 和已部署容器三方共享同一份数据。
#
# Server + 远程 Agent（docker-compose.server.yml，多台机器）：
#   必须是 NFS 共享目录，且所有机器（控制平面 + 所有 deploy agent 节点）均需以
#   完全相同的绝对路径挂载。
#   示例：VOLUME_NFS_BASE_PATH=/mnt/nfs/volumes
#   请先在各机器上配置 NFS 挂载（如通过 /etc/fstab），再设置此变量。
#   该路径会通过 /api/agent/config 自动下发给 deploy agent，无需在 agent 节点重复配置。
#
# VOLUME_NFS_BASE_PATH=/opt/muvee/volumes

# 数据集 NFS 基础路径（可选，不设置则禁用数据集功能）
#
# Dataset 的 `nfs_path` 需填写相对此目录的子路径。
# 示例：nfs_path=warehouse -> /mnt/nfs/datasets/warehouse
#
# 单机 Standalone（docker-compose.yml，所有组件在同一台机器）：
#   可直接使用本机本地目录。
#   示例：DATASET_NFS_BASE_PATH=/opt/muvee/datasets
#
# Server + 远程 Agent（docker-compose.server.yml，多台机器）：
#   必须是 NFS 共享目录，且控制平面与所有 deploy agent 节点均需以
#   完全相同的绝对路径挂载。
#   示例：DATASET_NFS_BASE_PATH=/mnt/nfs/datasets
#
# DATASET_NFS_BASE_PATH=/opt/muvee/datasets

# muvee-authservice 的内网地址（Traefik 和 muvee-server 均需可达）
# 默认值 http://muvee-authservice:4181 适用于同一 Docker Compose 网络的标准部署
AUTH_SERVICE_URL=http://muvee-authservice:4181

# Agent ↔ Server 共享密钥（server 和所有 agent 节点必须配置相同的值）
# 用于保护 /api/agent/* 端点，防止未授权节点注册或提交任务结果
# 生成示例：openssl rand -hex 32
AGENT_SECRET=change-me-agent-secret

# ── Agent 节点专用配置（以下变量仅在 agent 节点的 .env 中设置）──────────────
# 注意：REGISTRY_ADDR / REGISTRY_USER / REGISTRY_PASSWORD / BASE_DOMAIN
#       均由控制平面通过 /api/agent/config 自动下发，无需在 agent 节点重复配置。

# Agent 连接控制平面的内网地址
# ⚠️  必须使用内网地址，原因：
#   1. 自动 IP 检测依赖"去往控制平面走的网卡"，必须是内网接口
#   2. 无需经过公网，也无需 OAuth 验证（agent 端点仅用 AGENT_SECRET 保护）
# 示例（Docker Compose 同主机）：http://muvee-server:8080
# 示例（跨机器内网）：           http://10.0.0.1:8080
CONTROL_PLANE_URL=http://10.0.0.1:8080

# Deploy Agent 专用：节点对外暴露的 IP（Traefik 通过此 IP 路由到已部署容器）
# 留空时自动检测（通过向 CONTROL_PLANE_URL 的主机发起 UDP 探测，获取正确的内网接口 IP）
# 若自动检测结果不正确（如多网卡），可手动指定
# HOST_IP=10.0.1.5
