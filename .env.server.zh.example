# muvee 服务端环境配置模板
# 用于 docker-compose.server.yml，复制为 .env 后修改

# 身份认证 Provider（至少配置一个）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_BASE_URL=https://open.feishu.cn
# WECOM_CORP_ID=your-corp-id
# WECOM_CORP_SECRET=your-corp-secret
# WECOM_AGENT_ID=your-agent-id
# DINGTALK_CLIENT_ID=your-client-id
# DINGTALK_CLIENT_SECRET=your-client-secret

ALLOWED_DOMAINS=your-company.com
ADMIN_EMAILS=admin@your-company.com
BASE_DOMAIN=example.com
JWT_SECRET=change-me-to-a-random-secret

POSTGRES_PASSWORD=change-me-postgres-password
ACME_EMAIL=admin@example.com

REGISTRY_ADDR=registry.example.com
REGISTRY_USER=registry-user
REGISTRY_PASSWORD=change-me-registry-password

AUTH_SERVICE_URL=http://muvee-authservice:4181
AGENT_SECRET=change-me-agent-secret

# 工作区卷基础路径（可选）
# VOLUME_NFS_BASE_PATH=/mnt/nfs/volumes

# 数据集 NFS 基础路径（可选；使用 dataset 时必需）
# Dataset 的 nfs_path 需填写相对此目录的子路径
# （例如 nfs_path=warehouse -> /mnt/nfs/datasets/warehouse）。
# DATASET_NFS_BASE_PATH=/mnt/nfs/datasets

# Git 仓库基础路径（可选，不设置则禁用自托管 Git 仓库）
# 仅需在控制平面配置；Agent 通过 HTTP 克隆。
# GIT_REPO_BASE_PATH=/opt/muvee/git-repos
