# muvee Agent Environment Template
# Copy this file to .env for docker-compose.agent-*.yml

CONTROL_PLANE_URL=http://10.0.0.1:8080
AGENT_SECRET=change-me-agent-secret

# Deploy-only options
# DATA_DIR=/muvee/data
# HOST_IP=10.0.1.5

# Paths below are distributed from control plane via /api/agent/config.
# Set them here only when using docker-compose volume mounts.
# They MUST exactly match control-plane values.
# VOLUME_NFS_BASE_PATH=/mnt/nfs/volumes
# DATASET_NFS_BASE_PATH=/mnt/nfs/datasets
