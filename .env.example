# muvee 环境配置模板
# 复制为 .env 并填写实际值

# Google OAuth2 (从 https://console.cloud.google.com/apis/credentials 创建)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 允许登录的邮箱域名（逗号分隔，留空允许所有 Google 账号）
ALLOWED_DOMAINS=your-company.com

# 系统根域名（project 将以 {name}.BASE_DOMAIN 访问，控制台入口为 www.BASE_DOMAIN）
BASE_DOMAIN=example.com

# JWT 签名密钥（生产环境请使用随机字符串）
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL 密码
POSTGRES_PASSWORD=change-me-postgres-password

# Let's Encrypt 通知邮箱
ACME_EMAIL=admin@example.com
