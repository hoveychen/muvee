# muvee Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ── Identity Providers ───────────────────────────────────────────────────────
# At least one provider must be configured. Multiple providers can be enabled
# simultaneously; the login page will show a button for each enabled provider.

# Google OAuth2
# Setup: https://console.cloud.google.com/apis/credentials
# Add to "Authorized redirect URIs":
#   https://BASE_DOMAIN/auth/google/callback   ← control-panel login
#   https://BASE_DOMAIN/_oauth/google           ← per-project ForwardAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URL=https://example.com/auth/google/callback

# Feishu / Lark OAuth2
# Setup: https://open.feishu.cn/app → create app → add OAuth2 scope: contact:user.email:readonly
# Add redirect URIs:
#   https://BASE_DOMAIN/auth/feishu/callback   ← control-panel login
#   https://BASE_DOMAIN/_oauth/feishu           ← per-project ForwardAuth
# For international Lark, set FEISHU_BASE_URL=https://open.larksuite.com
# Email fallback: enterprise_email → email → {open_id}@feishu.local (see ALLOWED_DOMAINS note below)
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_REDIRECT_URL=https://example.com/auth/feishu/callback
# FEISHU_BASE_URL=https://open.feishu.cn

# WeCom / 企业微信 QR-code SSO
# Setup: https://work.weixin.qq.com/wework_admin/frame#apps → create app → configure OAuth
# Add redirect URIs:
#   https://BASE_DOMAIN/auth/wecom/callback     ← control-panel login
#   https://BASE_DOMAIN/_oauth/wecom            ← per-project ForwardAuth
# Email fallback: biz_mail → email → {userid}@wecom.local (see ALLOWED_DOMAINS note below)
# WECOM_CORP_ID=your-corp-id
# WECOM_CORP_SECRET=your-corp-secret
# WECOM_AGENT_ID=your-agent-id
# WECOM_REDIRECT_URL=https://example.com/auth/wecom/callback

# DingTalk / 钉钉 OAuth2
# Setup: https://open.dingtalk.com → create app → configure Login with DingTalk
# Add redirect URIs:
#   https://BASE_DOMAIN/auth/dingtalk/callback  ← control-panel login
#   https://BASE_DOMAIN/_oauth/dingtalk         ← per-project ForwardAuth
# Email fallback: email → {unionId}@dingtalk.local (see ALLOWED_DOMAINS note below)
# DINGTALK_CLIENT_ID=your-client-id
# DINGTALK_CLIENT_SECRET=your-client-secret
# DINGTALK_REDIRECT_URL=https://example.com/auth/dingtalk/callback

# Allowed email domains for login (comma-separated; leave empty to allow all accounts)
# For Google: restricts login to the specified domains (e.g. your-company.com).
# For Feishu / WeCom / DingTalk: ALLOWED_DOMAINS is only checked when the provider returns a
# real email address. If the provider cannot supply an email, a synthetic address ending in
# .local (e.g. abc123@feishu.local) is used instead — these bypass the domain check because
# the enterprise SSO itself already enforces organisation membership.
ALLOWED_DOMAINS=your-company.com

# Admin email addresses (comma-separated). These users are automatically granted the admin role
# on login and can access the Traefik dashboard at traefik.BASE_DOMAIN
ADMIN_EMAILS=admin@your-company.com

# Base domain (projects are accessible at {name}.BASE_DOMAIN; control panel at BASE_DOMAIN itself)
# DNS: point BASE_DOMAIN (A record) and *.BASE_DOMAIN (wildcard A record) to this server's IP
BASE_DOMAIN=example.com

# Multi-domain (optional): serve the SAME instance under more than one apex.
# Comma-separated list of ADDITIONAL base domains; BASE_DOMAIN stays the
# canonical default (used whenever a request host matches none of the list).
# Per request muvee resolves the matching base domain so the auth cookie, the
# OAuth redirect_uri, the Traefik router/cert set and the CORS gate all land on
# whichever domain the user is actually on. Leave empty for single-domain.
#   - Each extra base domain needs its own DNS: <base> (A) + *.<base> (wildcard A).
#   - There is no wildcard TLS for the extra domains — every project subdomain
#     gets its own HTTP-01 cert (see docs/configuration.md).
#   - Add each domain's OAuth callback to every provider dashboard you use, e.g.
#     https://app.<base>/auth/google/callback (panel) and
#     https://app.<base>/_oauth/google (per-project ForwardAuth).
# BASE_DOMAINS=muveeai.com,muvee.ai

# JWT signing secret (use a random string in production)
JWT_SECRET=change-me-to-a-random-secret

# Encryption key for stored secrets (required to use the secrets feature)
# Generate: openssl rand -hex 32
# Must be kept stable — changing it makes all existing secrets unreadable
SECRET_ENCRYPTION_KEY=change-me-secret-encryption-key

# PostgreSQL password
POSTGRES_PASSWORD=change-me-postgres-password

# Let's Encrypt notification email
ACME_EMAIL=admin@example.com

# Docker Registry configuration
# 1. Generate the registry/htpasswd file (run once on the control-plane server):
#    docker run --entrypoint htpasswd httpd:2 -Bbn <user> <password> > registry/htpasswd
# 2. After an agent starts, it automatically pulls the config below from the control plane
#    (/api/agent/config) — no need to configure these on agent nodes separately
REGISTRY_ADDR=registry.example.com
REGISTRY_USER=registry-user
REGISTRY_PASSWORD=change-me-registry-password

# Project workspace volume base path (optional — leave unset to disable the workspace feature)
#
# Enables a persistent per-project directory that is bind-mounted into each deployed container.
#
# Standalone (docker-compose.yml, single machine):
#   Any local directory — it is created automatically if it doesn't exist.
#   Example: VOLUME_NFS_BASE_PATH=/opt/muvee/volumes
#   The same path is mounted into muvee-server and muvee-agent-deploy containers,
#   so that all three parties (server API, deploy agent, and deployed containers) share the same files.
#
# Server + remote agents (docker-compose.server.yml, multiple machines):
#   Must be an NFS share mounted at the SAME absolute path on every machine
#   (control plane AND all deploy-agent nodes).
#   Example: VOLUME_NFS_BASE_PATH=/mnt/nfs/volumes
#   Mount NFS on each machine first (e.g. via /etc/fstab), then set this variable.
#   The path is automatically distributed to deploy agents via /api/agent/config.
#
# VOLUME_NFS_BASE_PATH=/opt/muvee/volumes

# Dataset NFS base path (optional — leave unset to disable the dataset feature)
#
# Dataset `nfs_path` values are relative sub-paths under this directory.
# Example: nfs_path=warehouse -> /mnt/nfs/datasets/warehouse
#
# Standalone (docker-compose.yml, single machine):
#   Any local directory can be used.
#   Example: DATASET_NFS_BASE_PATH=/opt/muvee/datasets
#
# Server + remote agents (docker-compose.server.yml, multiple machines):
#   Must be an NFS share mounted at the SAME absolute path on the control plane
#   and every deploy-agent node.
#   Example: DATASET_NFS_BASE_PATH=/mnt/nfs/datasets
#
# DATASET_NFS_BASE_PATH=/opt/muvee/datasets

# Git repository base path (optional — leave unset to disable hosted git repositories)
#
# Enables self-hosted git repositories served by the control plane.
# Each project can have its own bare git repo under this directory.
#
# Standalone (docker-compose.yml, single machine):
#   Any local directory — it is created automatically if it doesn't exist.
#   Example: GIT_REPO_BASE_PATH=/opt/muvee/git-repos
#
# Server + remote agents (docker-compose.server.yml, multiple machines):
#   A local directory on the control-plane server is sufficient (agents clone via HTTP).
#   Example: GIT_REPO_BASE_PATH=/opt/muvee/git-repos
#
# GIT_REPO_BASE_PATH=/opt/muvee/git-repos

# Tunnel backend URL (optional — required for the adhoc tunnel / publish feature)
#
# When set, enables `muveectl tunnel <PORT>` which creates a self-hosted ngrok-like
# tunnel from a local port to a public URL (e.g. t-bold-fox.example.com).
# This URL tells Traefik how to route tunnel traffic back to the muvee server.
#
# Standalone (docker-compose.yml): http://muvee-server:8080 (default)
# Multi-node:                      http://<control-plane-internal-ip>:8080
# TUNNEL_BACKEND_URL=http://muvee-server:8080

# Internal address of muvee-authservice (must be reachable by both Traefik and muvee-server)
# The default value http://muvee-authservice:4181 works for standard Docker Compose deployments
AUTH_SERVICE_URL=http://muvee-authservice:4181

# Shared secret between Agent ↔ Server (must be identical on the server and all agent nodes)
# Protects the /api/agent/* endpoints against unauthorized node registration or result submission
# Example generation: openssl rand -hex 32
AGENT_SECRET=change-me-agent-secret

# ── Agent-node-only configuration (set the variables below only in the agent node's .env) ────
# Note: REGISTRY_ADDR / REGISTRY_USER / REGISTRY_PASSWORD / BASE_DOMAIN
#       are automatically pushed from the control plane via /api/agent/config —
#       no need to duplicate them on agent nodes.

# Internal address the agent uses to reach the control plane
# ⚠️  Must be an internal/private address because:
#   1. Automatic IP detection relies on the interface used to reach the control plane
#   2. No need to go through the public internet or OAuth (agent endpoints use AGENT_SECRET only)
# Example (Docker Compose on the same host): http://muvee-server:8080
# Example (cross-machine internal network):  http://10.0.0.1:8080
CONTROL_PLANE_URL=http://10.0.0.1:8080

# Deploy-agent only: the public/internal IP exposed by this node
# (Traefik routes traffic to deployed containers via this IP)
# Leave empty for automatic detection (via a UDP probe toward CONTROL_PLANE_URL's host)
# Set manually if auto-detection picks the wrong interface (e.g. multi-NIC machines)
# HOST_IP=10.0.1.5

# ── Proxy (optional) ─────────────────────────────────────────────────────────
# To route builder agent / server / authservice traffic through an HTTP proxy,
# edit .proxy.env (already present in the repo) with your proxy address.
# docker compose picks it up automatically — no changes to .env needed.
#
# .proxy.env also controls BUILDER_PROXY_PASSTHROUGH (default: true).
# When enabled, HTTP_PROXY / HTTPS_PROXY / NO_PROXY are forwarded into every
# docker build as --build-arg, so pip/apt-get/curl inside Dockerfiles use the
# proxy without any Dockerfile changes. Set BUILDER_PROXY_PASSTHROUGH=false to
# isolate build-time network traffic from the proxy.

# ── Builder resource limits (optional, builder agent only) ───────────────────
# Cap per-build memory and concurrent builds so one project's build cannot OOM
# the shared host. Both are read by the builder agent on startup; leave them
# commented out to use the defaults shown.
#
# BUILDER_MEMORY_LIMIT — passed to docker buildx as --memory / --memory-swap
# (same format as docker: "3g", "512m"). Swap is locked to the same value so a
# build that hits the cap fails fast instead of thrashing the host. Default: 3g.
#BUILDER_MEMORY_LIMIT=3g
#
# BUILDER_MAX_CONCURRENT — max builds running in parallel on this node. The
# control plane can hand the agent several build tasks at once; without a cap
# they all start together and stack their memory usage. Anything that is not a
# positive integer falls back to the default. Raise it on a beefier box.
# Default: 1.
#BUILDER_MAX_CONCURRENT=1

# ── Auto-deploy (optional) ───────────────────────────────────────────────────
# When set to "auto-update", `docker compose up -d` also starts a watchtower
# sidecar that polls ghcr.io/hoveychen/muvee:latest every 60s and restarts the
# muvee containers (server/authservice/agent-builder/agent-deploy) when a new
# image is published. Postgres / Traefik / Registry stay pinned and untouched.
# Leave commented out to disable auto-update.
# COMPOSE_PROFILES=auto-update
