# muvee Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Google OAuth2
# Setup steps:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Click "Create Credentials" → "OAuth client ID", select "Web application"
# 3. Add BOTH of the following to "Authorized redirect URIs":
#    https://www.BASE_DOMAIN/auth/google/callback   ← control-panel login
#    https://www.BASE_DOMAIN/_oauth                 ← per-project ForwardAuth
#    (Replace BASE_DOMAIN with your actual domain, e.g. https://www.example.com/...)
# 4. Copy the Client ID and Client Secret into the fields below
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Allowed email domains for login (comma-separated; leave empty to allow all Google accounts)
ALLOWED_DOMAINS=your-company.com

# Admin email addresses (comma-separated). These users are automatically granted the admin role
# on login and can access the Traefik dashboard at traefik.BASE_DOMAIN
ADMIN_EMAILS=admin@your-company.com

# Base domain (projects are accessible at {name}.BASE_DOMAIN; control panel at www.BASE_DOMAIN)
BASE_DOMAIN=example.com

# JWT signing secret (use a random string in production)
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL password
POSTGRES_PASSWORD=change-me-postgres-password

# Let's Encrypt notification email
ACME_EMAIL=admin@example.com

# Docker Registry configuration
# 1. Generate the registry/htpasswd file (run once on the control-plane server):
#    docker run --entrypoint htpasswd httpd:2 -Bbn <user> <password> > registry/htpasswd
# 2. After an agent starts, it automatically pulls the config below from the control plane
#    (/api/agent/config) — no need to configure these on agent nodes separately
REGISTRY_ADDR=registry.example.com
REGISTRY_USER=registry-user
REGISTRY_PASSWORD=change-me-registry-password

# Internal address of muvee-authservice (must be reachable by both Traefik and muvee-server)
# The default value http://muvee-authservice:4181 works for standard Docker Compose deployments
AUTH_SERVICE_URL=http://muvee-authservice:4181

# Shared secret between Agent ↔ Server (must be identical on the server and all agent nodes)
# Protects the /api/agent/* endpoints against unauthorized node registration or result submission
# Example generation: openssl rand -hex 32
AGENT_SECRET=change-me-agent-secret

# ── Agent-node-only configuration (set the variables below only in the agent node's .env) ────
# Note: REGISTRY_ADDR / REGISTRY_USER / REGISTRY_PASSWORD / BASE_DOMAIN
#       are automatically pushed from the control plane via /api/agent/config —
#       no need to duplicate them on agent nodes.

# Internal address the agent uses to reach the control plane
# ⚠️  Must be an internal/private address because:
#   1. Automatic IP detection relies on the interface used to reach the control plane
#   2. No need to go through the public internet or OAuth (agent endpoints use AGENT_SECRET only)
# Example (Docker Compose on the same host): http://muvee-server:8080
# Example (cross-machine internal network):  http://10.0.0.1:8080
CONTROL_PLANE_URL=http://10.0.0.1:8080

# Deploy-agent only: the public/internal IP exposed by this node
# (Traefik routes traffic to deployed containers via this IP)
# Leave empty for automatic detection (via a UDP probe toward CONTROL_PLANE_URL's host)
# Set manually if auto-detection picks the wrong interface (e.g. multi-NIC machines)
# HOST_IP=10.0.1.5
