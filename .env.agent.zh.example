# muvee Agent 环境配置模板
# 用于 docker-compose.agent-*.yml，复制为 .env 后修改

CONTROL_PLANE_URL=http://10.0.0.1:8080
AGENT_SECRET=change-me-agent-secret

# 仅 Deploy 节点可选
# DATA_DIR=/muvee/data
# HOST_IP=10.0.1.5

# 下列路径会由控制平面通过 /api/agent/config 下发。
# 仅在 docker-compose 里做 volume 挂载时需要在本地填写。
# 必须与控制平面的值完全一致。
# VOLUME_NFS_BASE_PATH=/mnt/nfs/volumes
# DATASET_NFS_BASE_PATH=/mnt/nfs/datasets
